# Doxyfile 1.9.1
PROJECT_NAME           = "ncompile"
PROJECT_NUMBER         = "0.1.0"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
RECURSIVE              = YES

# Include the source and the generated TableGen files
INPUT                  = . \
                         include \
                         lib \
                         python \
                         tools \
                         build/include/ncompile/Dialect/QEC

EXCLUDE                = build/CMakeFiles \
                         build/python \
                         venv

GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
FILE_PATTERNS          = *.cpp *.h *.td *.py *.inc
EXTENSION_MAPPING      = inc=C++
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = YES
ALPHABETICAL_INDEX     = YES
COLS_IN_ALPHA_INDEX    = 5
GENERATE_TREEVIEW      = YES
USE_MATHJAX            = YES
